LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=LangServe-Ollama

APP_NAME=AI Model Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Comma separated list. Example: http://localhost:3000,http://localhost:8080
CORS_ORIGINS=*

MODEL_NAME=eeve_q40:latest
MODEL_TEMPERATURE=0
MODEL_NUM_PREDICT=512
MODEL_REPEAT_PENALTY=1.1
MODEL_STOP=<s>,</s>,<|im_end|>,Human:
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Optional. If set, /rag is enabled with this PDF file.
RAG_FILE_PATH=
RAG_EMBEDDING_MODEL=bge-m3
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=4
RAG_INDEX_DIR=.cache/faiss-index

# Meeting summary pipeline options
MEETING_CHUNK_SIZE=2000
MEETING_CHUNK_OVERLAP=200
MEETING_MAX_CHUNKS=24
MEETING_TEMPERATURE=0.1
MEETING_PARSE_RETRIES=1
